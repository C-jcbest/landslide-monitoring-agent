# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings (DeepSeek OpenAI-compatible API)
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_LLM_MODEL=deepseek-v4-flash
DEFAULT_LLM_TEMPERATURE=0.2
SESSION_NAMING_ENABLED=true

# Long-term memory (mem0 + NVIDIA AI Endpoints)
LONG_TERM_MEMORY_MODEL=deepseek-v4-flash
LONG_TERM_MEMORY_EMBEDDER_MODEL=nvidia/nv-embed-v1
LONG_TERM_MEMORY_EMBEDDER_DIMENSIONS=4096
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory_nv_embed_v1

# NVIDIA AI Endpoints
NVIDIA_API_KEY="your-nvidia-api-key"

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Beidou Monitoring Platform Settings
BEIDOU_API_BASE_URL=http://39.96.80.62/bdjc-api/v2/API
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BEIDOU_CREDENTIAL_ENCRYPTION_KEY="from-cryptography-fernet--import"

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_BEIDOU_CREDENTIALS="20 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Profiling Settings
PROFILING_DIR=/tmp/fastapi_profiles
PROFILING_THRESHOLD_SECONDS=2.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
